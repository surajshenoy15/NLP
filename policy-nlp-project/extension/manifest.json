{
  "manifest_version": 3,
  "name": "Policy AI",
  "description": "Understand policy PDFs instantly using NLP",
  "version": "1.0",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
